# =============================================================
# Gin Blog environment config
# Usage:
#   1. cp .env.example .env
#   2. edit .env
#   3. docker compose up -d --build
# =============================================================

# Nginx gateway public port
GATEWAY_PORT=80

# Backend app
SERVER_PORT=9090

# MySQL used by the Go backend
DB_HOST=mysql
DB_PORT=3306
DB_USER=blog_user
DB_PASSWORD=change_me_db_password
DB_NAME=blog

# MySQL container root password, used by docker-compose
DB_ROOT_PASSWORD=change_me_root_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-in-production-use-at-least-32-random-chars
JWT_EXPIRE_HOURS=168

# Log
LOG_LEVEL=info
LOG_FILENAME=logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=7
LOG_MAX_AGE=30

# Email, optional. Leave blank to disable email notification credentials.
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=博客评论通知
EMAIL_FROM_EMAIL=

# Blogger account/display config
BLOGGER_USER_ID=1
BLOGGER_USERNAME=admin
BLOGGER_PASSWORD=change_me_admin_password
BLOGGER_NICKNAME=博主
BLOGGER_EMAIL=
BLOGGER_AVATAR=/avatar.jpg

# App bootstrap
APP_SEED_DATA=true
APP_INIT_SQL_DIR=
