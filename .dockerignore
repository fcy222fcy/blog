# ============================================
# Git / IDE
# ============================================
.git
.gitignore
.vscode
.idea
*.swp
*.swo
*.iml

# ============================================
# Frontend: build artifacts and dependencies
# ============================================
blog-web/node_modules
blog-web/dist
blog-admin/node_modules
blog-admin/dist

# ============================================
# Backend: build artifacts
# ============================================
*.exe
*.out
*.test
blog-server
server

# ============================================
# Documentation and tests
# ============================================
docs/
test/
prototypes/
*.md
!scripts/README.md

# ============================================
# Docker self-reference (avoid COPY loops,
# but keep docker/nginx/nginx.conf for gateway build)
# ============================================
docker-compose*.yml
.env
.env.local
.env.prod
Dockerfile
.dockerignore
docker/*.md
docker/*.yml
docker/*.yaml

# ============================================
# Logs, cache, and temporary files
# ============================================
logs/
*.log
tmp/
cache/
uploads/

# ============================================
# Image assets: only exclude top-level loose files;
# frontend public/ assets are preserved via their build context.
# ============================================
/*.png
/*.jpg
/*.jpeg

# ============================================
# Misc
# ============================================
.mcp.json
.playwright-mcp/
email-prototype.htm
